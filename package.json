{
  "name": "linkedin-saved-posts-scraper",
  "version": "1.0.0",
  "description": "Extract LinkedIn saved posts with multimedia content",
  "main": "scraper.js",
  "type": "module",
  "scripts": {
    "scrape": "node scraper.js",
    "sync": "node sync-and-embed.js",
    "sync:visible": "node sync-and-embed.js --visible",
    "sync:scrape-only": "node scraper-incremental.js",
    "embed-only": "node sync-and-embed.js --embed-only",
    "scheduler:setup": "node setup-scheduler.js",
    "scheduler:remove": "node setup-scheduler.js --remove",
    "server": "node server.js",
    "viewer": "concurrently \"node server.js\" \"cd viewer && npm run dev\"",
    "embeddings": "node generate-embeddings.js",
    "upgrade": "node upgrade-quality.js",
    "upgrade:videos": "node upgrade-videos.js",
    "install-browsers": "npx playwright install chromium"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
