# LinkedIn credentials (optional — only needed for automated login)
# If left blank, the scraper will use your existing Chrome browser session
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-password

# Optional: limit number of posts to scrape (0 = all)
MAX_POSTS=0

# Chrome profile (optional — defaults to LOCALAPPDATA path and "Default" profile)
# CHROME_USER_DATA=C:/Users/YourName/AppData/Local/Google/Chrome/User Data
# CHROME_PROFILE=Default

# vLLM server URL for semantic search (embedding model)
# Runs locally via Docker on port 8691 by default
# VLLM_URL=http://localhost:8691

# Docker vLLM port (default: 8691)
# VLLM_PORT=8691
